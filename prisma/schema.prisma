generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Projects {
  projectId      Int             @id @unique @default(autoincrement())
  projectName    String          @db.VarChar
  description    String?         @db.VarChar
  createdBy      Int?
  createdAt      DateTime?       @default(now()) @db.Timestamptz(6)
  dueDate        DateTime        @db.Timestamptz(6)
  completionDate DateTime?       @db.Timestamptz(6)
  status         status_enum     @default(todo)
  Users          Users?          @relation(fields: [createdBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  tasks          tasks[]
  user_projects  user_projects[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TaskComments {
  commentId   Int       @id @unique @default(autoincrement())
  taskId      Int
  userId      Int?
  commentText String    @db.VarChar
  createdDate DateTime? @default(now()) @db.Timestamptz(6)
  tasks       tasks     @relation(fields: [taskId], references: [taskId], onDelete: NoAction, onUpdate: NoAction)
  Users       Users?    @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TaskHistory {
  historyId  Int       @id @unique @default(autoincrement())
  taskId     Int
  changedBy  Int?
  changeType String    @db.VarChar
  changeTime DateTime? @default(now()) @db.Timestamptz(6)
  Users      Users?    @relation(fields: [changedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  tasks      tasks     @relation(fields: [taskId], references: [taskId], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Users {
  userId        Int             @id @unique @default(autoincrement())
  userName      String          @unique @db.VarChar
  email         String          @unique @db.VarChar
  passwordHash  String          @db.VarChar
  createdAt     DateTime?       @default(now()) @db.Timestamptz(6)
  role          role_enum       @default(member)
  Projects      Projects[]
  TaskComments  TaskComments[]
  TaskHistory   TaskHistory[]
  tasks         tasks[]
  user_projects user_projects[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_projects {
  up_id     Int       @id @default(autoincrement())
  userid    Int?
  projectid Int?
  Projects  Projects? @relation(fields: [projectid], references: [projectId], onDelete: Cascade, onUpdate: NoAction)
  Users     Users?    @relation(fields: [userid], references: [userId], onDelete: Cascade, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tasks {
  taskId         Int            @id @default(autoincrement())
  assignedto     Int?
  title          String         @db.VarChar(100)
  description    String?        @db.VarChar(255)
  dueDate        DateTime?      @db.Timestamptz(6)
  createdAt      DateTime?      @default(now()) @db.Timestamptz(6)
  completionDate DateTime?      @db.Timestamptz(6)
  status         status_enum    @default(todo)
  points         Int            @default(0)
  projectId      Int
  priority       priority_enum  @default(Low)
  TaskComments   TaskComments[]
  TaskHistory    TaskHistory[]
  Projects       Projects       @relation(fields: [projectId], references: [projectId], onDelete: Cascade, map: "Tasks_projectId_fkey")
  Users          Users?         @relation(fields: [assignedto], references: [userId], onDelete: NoAction, onUpdate: NoAction)
}

enum role_enum {
  admin
  manager
  member
}

enum status_enum {
  todo
  pending
  completed
}

enum priority_enum {
  Low
  High
  Medium
}
