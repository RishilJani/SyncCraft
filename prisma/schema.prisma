generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Projects {
  projectId      BigInt      @id @unique @default(autoincrement())
  projectName    String      @db.VarChar
  description    String?     @db.VarChar
  createdBy      BigInt?
  createdAt      DateTime?   @default(now()) @db.Timestamptz(6)
  dueDate        DateTime    @db.Timestamptz(6)
  status         BigInt
  completionDate DateTime?   @db.Timestamptz(6)
  Users          Users?      @relation(fields: [createdBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  Tags           Tags        @relation(fields: [status], references: [tagId], onDelete: NoAction, onUpdate: NoAction)
  TaskLists      TaskLists[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TaskComments {
  commentId   BigInt    @id @unique @default(autoincrement())
  taskId      BigInt
  userId      BigInt?
  commentText String    @db.VarChar
  createdDate DateTime? @default(now()) @db.Timestamptz(6)
  tasks       Tasks     @relation(fields: [taskId], references: [taskId], onDelete: NoAction, onUpdate: NoAction)
  Users       Users?    @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TaskHistory {
  historyId  BigInt    @id @unique @default(autoincrement())
  taskId     BigInt
  changedBy  BigInt?
  changeType String    @db.VarChar
  changeTime DateTime? @default(now()) @db.Timestamptz(6)
  Users      Users?    @relation(fields: [changedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  tasks      Tasks     @relation(fields: [taskId], references: [taskId], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TaskLists {
  listId    BigInt   @id @unique @default(autoincrement())
  projectId BigInt
  listName  String   @db.VarChar
  Projects  Projects @relation(fields: [projectId], references: [projectId], onDelete: NoAction, onUpdate: NoAction)
  Tasks     Tasks[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model UserRoles {
  userRoleId BigInt    @id @unique @default(autoincrement())
  userId     BigInt
  roleName   role_enum @default(member)
  Users      Users     @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Users {
  userId       BigInt         @id @unique @default(autoincrement())
  userName     String         @unique @db.VarChar
  email        String         @unique @db.VarChar
  passwordHash String         @db.VarChar
  createdAt    DateTime?      @default(now()) @db.Timestamptz(6)
  Projects     Projects[]
  TaskComments TaskComments[]
  TaskHistory  TaskHistory[]
  Tasks        Tasks[]
  UserRoles    UserRoles[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tasks {
  taskId         BigInt         @id(map: "tasks_pkey") @default(autoincrement())
  listid         BigInt?
  assignedto     BigInt?
  title          String         @db.VarChar(100)
  description    String?        @db.VarChar(255)
  priority       String?        @db.VarChar(10)
  dueDate        DateTime?      @db.Timestamptz(6)
  createdAt      DateTime?      @default(now()) @db.Timestamptz(6)
  status         BigInt
  completionDate DateTime?      @db.Timestamptz(6)
  TaskComments   TaskComments[]
  TaskHistory    TaskHistory[]
  Tags           Tags           @relation(fields: [status], references: [tagId], onDelete: NoAction, onUpdate: NoAction)
  Users          Users?         @relation(fields: [assignedto], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "tasks_assignedto_fkey")
  TaskLists      TaskLists?     @relation(fields: [listid], references: [listId], onDelete: NoAction, onUpdate: NoAction, map: "tasks_listid_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tags {
  tagId    BigInt     @id @unique @default(autoincrement())
  tagName  String     @unique
  Projects Projects[]
  Tasks    Tasks[]
}

enum role_enum {
  admin
  manager
  member
}
